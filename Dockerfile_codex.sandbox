FROM ubuntu:24.04 AS isolate-builder

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
	apt-get install -y --no-install-recommends \
		ca-certificates \
		git \
		make \
		gcc \
		libc-dev \
		libcap-dev && \
	rm -rf /var/lib/apt/lists/*

RUN git clone https://github.com/envicutor/isolate.git /tmp/isolate && \
	cd /tmp/isolate && \
	git checkout af6db68042c3aa0ded80787fbb78bc0846ea2114 && \
	make -j"$(nproc)" install && \
	rm -rf /tmp/isolate


FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
	apt-get install -y --no-install-recommends \
		bash \
		ca-certificates \
		coreutils \
		curl \
		git \
		gnupg \
		locales \
		procps \
		python3 \
		rename \
		tar \
		util-linux \
		binutils \
		build-essential \
		libc6-dev \
		libxml2 \
		libpcre3-dev \
		libevent-dev \
		libgmp-dev \
		libncurses-dev \
		libedit-dev \
		libseccomp-dev \
		libreadline-dev \
		libblas-dev \
		liblapack-dev \
		libarpack2-dev \
		libfftw3-dev \
		libglpk-dev \
		libqhull-dev \
		libqrupdate-dev \
		libsuitesparse-dev \
		libsundials-dev \
		libpcre2-dev \
		libcap-dev \
		nodejs \
		npm && \
	rm -rf /var/lib/apt/lists/*

RUN sed -i '/en_US.UTF-8/s/^# //g' /etc/locale.gen && locale-gen

RUN useradd -m -s /bin/bash piston

COPY --from=isolate-builder /usr/local/bin/isolate /usr/local/bin/isolate
COPY --from=isolate-builder /usr/local/etc/isolate /usr/local/etc/isolate

WORKDIR /piston_api
COPY api/package.json api/package-lock.json ./
RUN npm ci --omit=dev
COPY api/src ./src

RUN chmod +x /piston_api/src/docker-entrypoint.sh

WORKDIR /piston
RUN mkdir -p /piston/packages /piston/jobs && chown -R piston:piston /piston

RUN mkdir -p /opt/piston-seed/packages /opt/piston-seed/jobs

WORKDIR /piston_api
RUN PISTON_DATA_DIRECTORY=/opt/piston-seed node -e "require('nocamel');const Package=require('./src/package');(async()=>{const pkg=await Package.get_package('python','*');if(!pkg){throw new Error('python package not found in repo index');}await pkg.install();})().catch(err=>{console.error(err);process.exit(1);});"

EXPOSE 2000

CMD ["/piston_api/src/docker-entrypoint.sh"]
